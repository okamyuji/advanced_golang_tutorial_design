# MySQL 8.0 高性能・並行処理最適化設定

[mysqld]
# 基本設定
port = 3306
bind-address = 0.0.0.0
socket = /var/run/mysqld/mysqld.sock
datadir = /var/lib/mysql
tmpdir = /tmp

# サーバー識別
server-id = 1

# 文字セット設定
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
default-time-zone = '+09:00'

# SQL Mode設定（厳密モード）
sql_mode = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION

# 接続設定
max_connections = 200
max_user_connections = 180
max_connect_errors = 100000
connect_timeout = 10
wait_timeout = 28800
interactive_timeout = 28800

# メモリ設定
# InnoDB Buffer Pool（利用可能メモリの70-80%）
innodb_buffer_pool_size = 512M
innodb_buffer_pool_instances = 4
innodb_buffer_pool_chunk_size = 128M

# テーブルキャッシュ
table_open_cache = 4000
table_definition_cache = 2000
table_open_cache_instances = 16

# クエリキャッシュ（MySQL 8.0では削除されたが、記録として残す）
# query_cache_type = 1
# query_cache_size = 128M

# ソート・グループ処理用メモリ
sort_buffer_size = 2M
read_buffer_size = 128K
read_rnd_buffer_size = 256K
join_buffer_size = 2M

# 一時テーブル設定
tmp_table_size = 128M
max_heap_table_size = 128M

# 並行処理設定
innodb_thread_concurrency = 0
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_purge_threads = 4
innodb_page_cleaners = 4

# ログ設定
# エラーログ
log-error = /var/log/mysql/error.log

# スロークエリログ
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1.0
log_queries_not_using_indexes = 1
log_slow_admin_statements = 1
log_slow_slave_statements = 1

# バイナリログ（レプリケーション用）
log-bin = mysql-bin
binlog_format = ROW
binlog_row_image = FULL
expire_logs_days = 7
max_binlog_size = 512M

# InnoDB設定
default_storage_engine = InnoDB

# InnoDB ログ設定
innodb_log_file_size = 512M
innodb_log_files_in_group = 2
innodb_log_buffer_size = 64M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method = O_DIRECT

# InnoDB ファイル設定
innodb_file_per_table = 1
innodb_data_file_path = ibdata1:100M:autoextend
innodb_autoextend_increment = 100

# InnoDB パフォーマンス設定
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
innodb_flush_neighbors = 0
innodb_doublewrite = 1
innodb_checksum_algorithm = crc32

# InnoDB ロック設定
innodb_lock_wait_timeout = 60
innodb_rollback_on_timeout = 1
innodb_deadlock_detect = 1

# InnoDB 統計情報
innodb_stats_persistent = 1
innodb_stats_on_metadata = 0
innodb_stats_sample_pages = 64

# MyISAM設定（互換性のため）
key_buffer_size = 128M
myisam_sort_buffer_size = 128M
myisam_max_sort_file_size = 2G
myisam_repair_threads = 1

# 最適化設定
optimizer_switch = 'index_merge=on,index_merge_union=on,index_merge_sort_union=on,index_merge_intersection=on,engine_condition_pushdown=on,index_condition_pushdown=on,mrr=on,mrr_cost_based=on,block_nested_loop=on,batched_key_access=off,materialization=on,semijoin=on,loosescan=on,firstmatch=on,duplicateweedout=on,subquery_materialization_cost_based=on,use_index_extensions=on,condition_fanout_filter=on,derived_merge=on'

# その他の設定
# セキュリティ
skip-name-resolve
local-infile = 0

# パフォーマンススキーマ
performance_schema = ON
performance_schema_max_table_instances = 400
performance_schema_max_table_handles = 4000

# Group Replication（クラスター用）
# plugin_load_add = 'group_replication.so'
# loose-group_replication_group_name = "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
# loose-group_replication_start_on_boot = off
# loose-group_replication_local_address = "127.0.0.1:33061"
# loose-group_replication_group_seeds = "127.0.0.1:33061"

# SSL設定（本番環境用）
# ssl-ca = /var/lib/mysql/ca.pem
# ssl-cert = /var/lib/mysql/server-cert.pem
# ssl-key = /var/lib/mysql/server-key.pem

# 開発環境用設定
# 厳密なSQL設定を緩和（必要に応じて）
# sql_mode = ''

[mysql]
default-character-set = utf8mb4

[mysqldump]
single-transaction
routines
triggers

[client]
default-character-set = utf8mb4
port = 3306
socket = /var/run/mysqld/mysqld.sock

[mysqld_safe]
log-error = /var/log/mysql/error.log
pid-file = /var/run/mysqld/mysqld.pid

# mysqlhotcopy設定
[mysqlhotcopy]
interactive-timeout

# innodb_ruby設定
[xtrabackup]
target_dir = /var/backups/mysql
